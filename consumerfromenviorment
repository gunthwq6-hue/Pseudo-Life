local function EnviormentalGenesis()
	
	local OFfset = 16.1 / 5.25
   
	local SpawnTarget = Center + Vector3.new(math.random(-S, S),0,math.random(-S,S))

    local newColor = BrickColor.random()
    
	local Clone = Model:Clone()
	
	local Array = Clone:GetDescendants()
	
	for i,v in ipairs(Array) do
		if v:IsA("BasePart") then
			v.BrickColor = newColor
		end
	end

	table.insert(RootConsumerTable, Clone)
    --SendDatatoParent(RootConsumerTable)
	
	Clone.Parent = workspace.Consumer
	
	Clone:MoveTo(SpawnTarget)
	
	print("Root Consumer added")

end



CEG.Event:Connect(function()
	for i = 1, 6, 1 do
		EnviormentalGenesis()
	end
end)
