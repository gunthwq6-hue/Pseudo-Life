function Table_A()  --ID | 0A |--
	--print("Calling 0A")
	local Producers = workspace.Producer:GetChildren()
	local Targets = {}

	for i, v in ipairs(Producers) do
		if v:IsA("BasePart") then
			table.insert(Targets, v)
		end
	end
	--print("Table search finished there are ,"  , #Targets, "that are possible to consume")
	return Targets, #Targets
end




function GetPlantInfo() --ID | 1A-AUX-A |--
	--print("Calling 1A-AUX-A")
	local Group = Table_A()

	local GroupPopulation = #Group

	return Group, GroupPopulation

end

function Table_B() --ID | 1A |--

	local Targets, localPopulation = Table_A()

	local Polished = {}

	for i,v in ipairs(Targets) do
		local Distance = (Core.PrimaryPart.Position - v.Position).Magnitude

		if Distance < Filter then
			table.insert(Polished, v)

		end
	end
	if #Polished == 0 then
		Adjuster()
		return
	end
	--print("Table Narrowed", #Polished)
	return Polished
end

function Adjuster() --ID | 1A-AUX-B |--

	local Table, Population = GetPlantInfo()

	if Population < Filter then
		Filter = math.abs(Filter - 6)
	elseif Population > Filter then
		Filter = Filter + 6
	end


	--print(Population)

	return Filter
end

function getTargetfromRandom() --ID | 2A |--
	--print("Calling 2A")
	local Group = Table_B()
	if not Group or #Group == 0 then
		return nil
	end


	local randomIndex = math.random(1, #Group)

	--print("Random Target Selected", DateTime.now())
	return Group[randomIndex]
end


function Translate() --ID | 3A |--

	local target = getTargetfromRandom()

	if not target then
		return
	end




	Core.Humanoid:MoveTo(target.Position)

	--print(ID, "Has commenced movement to", target.Position, ID, "Has", Nutrition, "Stored", "Key : 3A-TRANSLATE")

	Core.Humanoid.Touched:Connect(function(otherPart)

		if otherPart.Name == "Plant" then
			otherPart:Destroy()
			Nutrition += .05
			Gestation()

			--print("TargetDestroyed")
		end
	end)


	Core.Humanoid.MoveToFinished:Wait()
end

