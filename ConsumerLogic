function GetConsumerPopulation()
	local Consumers = workspace.Consumer:GetChildren()

	local PopulationLibary = {}

	local NumberofConsumers = nil

	for i,v in ipairs(Consumers) do
		if v:IsA("Model") then
			table.insert(PopulationLibary, v)

			NumberofConsumers = #PopulationLibary
		end
	end

	return NumberofConsumers
end

function GetConsumerData()
	local Consumers = workspace.Consumer:GetChildren()

	local PopulationLibary = {}

	local ConsumerData = nil

	for i,v in ipairs(Consumers) do
		if v:IsA("Model") then
			table.insert(PopulationLibary, v)

			ConsumerData = PopulationLibary
		end
	end

	return ConsumerData
end



