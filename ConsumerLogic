function GetfiltiredConsumerDistancePool()
	local Table1 = GetConsumerData()
	
	local Table2 = {}
	
	for i,v in ipairs(Table1) do
		local Distance = (Core.PrimaryPart.Position.Magnitude) - (v.PrimaryPart.Position.Magnitude)
		
		if Distance < ConsumerDistance then
			table.insert(Table2, v, Distance)
		end
	end
	
	return Table2
end
	

function GetClosestConsumer() 
	local Pool = GetfiltiredConsumerDistancePool()
	
	local Pool2 = table.sort(Pool)
	
	local First = nil
	
	for i,v in ipairs(Pool2) do
		if i == 1  then
			return v
		end
	end
end

function GetConsumerPoolWeight()
	local Input = GetfiltiredConsumerDistancePool()
	
	local Weight = (Input / Pi) / #Input * 2
	
	return Weight
end

function GetConsumerClosestWeight()
	local Input1, Input2 = GetClosestConsumer() GetConsumerPoolWeight()
	
	local Weight = Input1 * Input2
	
	return Weight
end

function GetConsuerPriorityFactor()
	local Weight1 = GetConsumerPoolWeight()
	
	local Weight2 = GetConsumerClosestWeight()
	
	local Factor = (Weight1 * Weight2) / 2
	
	return Factor
	
end
	
	
